# URL of your Ollama server (local or on your LAN)
OLLAMA_BASE_URL=http://localhost:11434

# The chat model every agent uses (needs solid tool-calling)
CHAT_MODEL=gpt-oss:20b

# The embedding model used to index the rulebook
EMBED_MODEL=nomic-embed-text

# Where the Chroma vector index for the rules is stored
CHROMA_DIR=./chroma_rules

# Where character sheets are saved as JSON
CHARACTER_DIR=./characters
